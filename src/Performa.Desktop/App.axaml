<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:infra="clr-namespace:Performa.Desktop.Infrastructure"
             x:Class="Performa.Desktop.App"
             RequestedThemeVariant="Dark">

  <Application.DataTemplates>
    <infra:ViewLocator />
  </Application.DataTemplates>

  <Application.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceInclude Source="avares://Performa.Desktop/Themes/Tokens.axaml" />
        <ResourceInclude Source="avares://Performa.Desktop/Themes/Icons.axaml" />
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </Application.Resources>

  <Application.Styles>
    <FluentTheme />
    <StyleInclude Source="avares://Performa.Desktop/Themes/Styles.axaml" />
  </Application.Styles>
</Application>
