<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!-- Carbon surfaces: lifted off pure black, faintly cool -->
  <Color x:Key="BgBase">#1C1E22</Color>
  <Color x:Key="BgSidebar">#212429</Color>
  <Color x:Key="BgCard">#262931</Color>
  <Color x:Key="BgCardHover">#2E313A</Color>
  <Color x:Key="BgInset">#17191D</Color>
  <Color x:Key="BorderSoft">#33363F</Color>
  <Color x:Key="BorderStrong">#434753</Color>

  <!-- Text -->
  <Color x:Key="TextPrimary">#ECEDF0</Color>
  <Color x:Key="TextMuted">#9A9DA8</Color>
  <Color x:Key="TextFaint">#666A76</Color>

  <!-- Accent + semantics -->
  <Color x:Key="Accent">#7C6CF0</Color>
  <Color x:Key="AccentBright">#9B8BFF</Color>
  <Color x:Key="Positive">#4FB286</Color>
  <Color x:Key="Warning">#E0A34E</Color>
  <Color x:Key="Danger">#E0655E</Color>
  <Color x:Key="Info">#4AA8E0</Color>

  <SolidColorBrush x:Key="BgBaseBrush" Color="{StaticResource BgBase}" />
  <SolidColorBrush x:Key="BgSidebarBrush" Color="{StaticResource BgSidebar}" />
  <SolidColorBrush x:Key="BgCardBrush" Color="{StaticResource BgCard}" />
  <SolidColorBrush x:Key="BgCardHoverBrush" Color="{StaticResource BgCardHover}" />
  <SolidColorBrush x:Key="BgInsetBrush" Color="{StaticResource BgInset}" />
  <SolidColorBrush x:Key="BorderSoftBrush" Color="{StaticResource BorderSoft}" />
  <SolidColorBrush x:Key="BorderStrongBrush" Color="{StaticResource BorderStrong}" />
  <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimary}" />
  <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMuted}" />
  <SolidColorBrush x:Key="TextFaintBrush" Color="{StaticResource TextFaint}" />
  <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource Accent}" />
  <SolidColorBrush x:Key="AccentBrightBrush" Color="{StaticResource AccentBright}" />
  <SolidColorBrush x:Key="PositiveBrush" Color="{StaticResource Positive}" />
  <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource Warning}" />
  <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource Danger}" />
  <SolidColorBrush x:Key="InfoBrush" Color="{StaticResource Info}" />
  <SolidColorBrush x:Key="AccentSoftBrush" Color="{StaticResource Accent}" Opacity="0.16" />

  <!-- App backdrop: carbon with a soft diagonal lift, echoing the site hero -->
  <LinearGradientBrush x:Key="BgBackdrop" StartPoint="0%,0%" EndPoint="80%,100%">
    <GradientStop Offset="0" Color="#24262D" />
    <GradientStop Offset="0.45" Color="#1E2025" />
    <GradientStop Offset="1" Color="#191B1F" />
  </LinearGradientBrush>

  <!-- Content backdrop: a touch lighter than the shell so panels read forward -->
  <LinearGradientBrush x:Key="BgContentBackdrop" StartPoint="0%,0%" EndPoint="100%,100%">
    <GradientStop Offset="0" Color="#212429" />
    <GradientStop Offset="0.6" Color="#1D1F24" />
    <GradientStop Offset="1" Color="#1B1D21" />
  </LinearGradientBrush>

  <LinearGradientBrush x:Key="AccentGradient" StartPoint="0%,0%" EndPoint="100%,100%">
    <GradientStop Offset="0" Color="#7C6CF0" />
    <GradientStop Offset="1" Color="#B06CE0" />
  </LinearGradientBrush>

  <FontFamily x:Key="MonoFont">Cascadia Code,Consolas,Menlo,monospace</FontFamily>

</ResourceDictionary>
