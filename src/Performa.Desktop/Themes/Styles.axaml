<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!-- Card container -->
  <Style Selector="Border.card">
    <Setter Property="Background" Value="{DynamicResource BgCardBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource BorderSoftBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="12" />
    <Setter Property="Padding" Value="18" />
    <Setter Property="BoxShadow" Value="0 2 10 0 #33000000" />
    <Setter Property="Transitions">
      <Transitions>
        <BrushTransition Property="Background" Duration="0:0:0.18" />
        <BrushTransition Property="BorderBrush" Duration="0:0:0.18" />
      </Transitions>
    </Setter>
  </Style>
  <Style Selector="Border.card.hover:pointerover">
    <Setter Property="Background" Value="{DynamicResource BgCardHoverBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource BorderStrongBrush}" />
    <Setter Property="BoxShadow" Value="0 6 20 0 #4D000000" />
  </Style>

  <!-- Section + heading text -->
  <Style Selector="TextBlock.h1">
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    <Setter Property="FontSize" Value="26" />
    <Setter Property="FontWeight" Value="SemiBold" />
  </Style>
  <Style Selector="TextBlock.h2">
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    <Setter Property="FontSize" Value="16" />
    <Setter Property="FontWeight" Value="SemiBold" />
  </Style>
  <Style Selector="TextBlock.label">
    <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
    <Setter Property="FontSize" Value="11" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="LetterSpacing" Value="1.2" />
  </Style>
  <Style Selector="TextBlock.muted">
    <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
    <Setter Property="FontSize" Value="13" />
  </Style>
  <Style Selector="TextBlock.faint">
    <Setter Property="Foreground" Value="{DynamicResource TextFaintBrush}" />
    <Setter Property="FontSize" Value="12" />
  </Style>
  <Style Selector="TextBlock.mono">
    <Setter Property="FontFamily" Value="{DynamicResource MonoFont}" />
    <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
    <Setter Property="FontSize" Value="12" />
  </Style>

  <!-- Nav item button -->
  <Style Selector="RadioButton.nav">
    <Setter Property="Template">
      <ControlTemplate>
        <Border Name="root" Background="Transparent" CornerRadius="9" Padding="12,9"
                Margin="0,1">
          <ContentPresenter Content="{TemplateBinding Content}" />
        </Border>
      </ControlTemplate>
    </Setter>
    <Setter Property="Transitions">
      <Transitions>
        <BrushTransition Property="Background" Duration="0:0:0.15" />
      </Transitions>
    </Setter>
  </Style>
  <Style Selector="RadioButton.nav /template/ Border#root:pointerover">
    <Setter Property="Background" Value="{DynamicResource BgCardHoverBrush}" />
  </Style>
  <Style Selector="RadioButton.nav:checked /template/ Border#root">
    <Setter Property="Background" Value="{DynamicResource AccentSoftBrush}" />
  </Style>

  <!-- Accent button -->
  <Style Selector="Button.accent">
    <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
    <Setter Property="Foreground" Value="White" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="FontSize" Value="13" />
    <Setter Property="Padding" Value="16,9" />
    <Setter Property="CornerRadius" Value="8" />
    <Setter Property="Cursor" Value="Hand" />
  </Style>
  <Style Selector="Button.accent:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource AccentBrightBrush}" />
  </Style>

  <Style Selector="Button.ghost">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource BorderSoftBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="FontSize" Value="13" />
    <Setter Property="Padding" Value="14,8" />
    <Setter Property="CornerRadius" Value="8" />
    <Setter Property="Cursor" Value="Hand" />
  </Style>
  <Style Selector="Button.ghost:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource BgCardHoverBrush}" />
    <Setter Property="TextElement.Foreground" Value="{DynamicResource TextPrimaryBrush}" />
  </Style>

  <!-- Quick-action card button -->
  <Style Selector="Button.qcard">
    <Setter Property="Background" Value="{DynamicResource BgCardBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource BorderSoftBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="12" />
    <Setter Property="Padding" Value="16" />
    <Setter Property="Cursor" Value="Hand" />
    <Setter Property="HorizontalContentAlignment" Value="Left" />
    <Setter Property="HorizontalAlignment" Value="Stretch" />
  </Style>
  <Style Selector="Button.qcard:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource BgCardHoverBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
  </Style>

  <!-- Inputs: seamless, part of the card rather than a dark well -->
  <Style Selector="TextBox">
    <Setter Property="Background" Value="{DynamicResource BgCardHoverBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource BorderSoftBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="8" />
    <Setter Property="Padding" Value="12,8" />
    <Setter Property="MinHeight" Value="38" />
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    <Setter Property="SelectionBrush" Value="{DynamicResource AccentSoftBrush}" />
    <Setter Property="CaretBrush" Value="{DynamicResource AccentBrightBrush}" />
  </Style>
  <Style Selector="TextBox:focus">
    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
  </Style>

  <!-- Dropdowns: same carbon, rounded, list wraps instead of stretching -->
  <Style Selector="ComboBox">
    <Setter Property="Background" Value="{DynamicResource BgCardHoverBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource BorderSoftBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="8" />
    <Setter Property="Padding" Value="12,8" />
    <Setter Property="MinHeight" Value="38" />
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    <Setter Property="HorizontalContentAlignment" Value="Left" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
  </Style>
  <Style Selector="ComboBox:focus">
    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
  </Style>
  <Style Selector="ComboBoxItem">
    <Setter Property="Padding" Value="12,8" />
    <Setter Property="CornerRadius" Value="6" />
    <Setter Property="Margin" Value="3,1" />
    <Setter Property="HorizontalContentAlignment" Value="Left" />
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
  </Style>
  <Style Selector="ComboBoxItem TextBlock">
    <Setter Property="TextWrapping" Value="Wrap" />
  </Style>
  <Style Selector="ComboBoxItem:pointerover">
    <Setter Property="Background" Value="{DynamicResource BgCardHoverBrush}" />
  </Style>
  <Style Selector="ComboBoxItem:selected">
    <Setter Property="Background" Value="{DynamicResource AccentSoftBrush}" />
  </Style>

  <!-- Featured nav item (Assistant): lifted above the rest -->
  <Style Selector="ListBox.nav ListBoxItem.featured /template/ Border#root">
    <Setter Property="Background" Value="{DynamicResource AccentSoftBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
    <Setter Property="BorderThickness" Value="1" />
  </Style>

  <!-- Circular refresh affordance -->
  <Style Selector="Button.spin">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Padding" Value="6" />
    <Setter Property="CornerRadius" Value="20" />
    <Setter Property="Cursor" Value="Hand" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>
  <Style Selector="Button.spin:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource BgCardHoverBrush}" />
  </Style>
  <Style Selector="Button.spin Path">
    <Setter Property="RenderTransformOrigin" Value="50%,50%" />
  </Style>
  <Style Selector="Button.spin.busy Path">
    <Style.Animations>
      <Animation Duration="0:0:1.1" IterationCount="INFINITE" Easing="LinearEasing">
        <KeyFrame Cue="0%"><Setter Property="RotateTransform.Angle" Value="0" /></KeyFrame>
        <KeyFrame Cue="100%"><Setter Property="RotateTransform.Angle" Value="360" /></KeyFrame>
      </Animation>
    </Style.Animations>
  </Style>

  <!-- Assistant: the one premium surface in the sidebar -->
  <Style Selector="Button.assistantcard">
    <Setter Property="Background" Value="{DynamicResource AssistantGradient}" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="CornerRadius" Value="12" />
    <Setter Property="Padding" Value="14,13" />
    <Setter Property="Cursor" Value="Hand" />
    <Setter Property="HorizontalAlignment" Value="Stretch" />
    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
  </Style>
  <Style Selector="Button.assistantcard:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource AssistantGradient}" />
    <Setter Property="Opacity" Value="0.9" />
  </Style>

  <!-- Pill / chip -->
  <Style Selector="Border.chip">
    <Setter Property="Background" Value="{DynamicResource BgInsetBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource BorderSoftBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="20" />
    <Setter Property="Padding" Value="10,3" />
  </Style>

  <!-- Sidebar nav list -->
  <Style Selector="ListBox.nav">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Padding" Value="0" />
  </Style>
  <Style Selector="ListBox.nav ListBoxItem">
    <Setter Property="Padding" Value="0" />
    <Setter Property="Margin" Value="0,1" />
    <Setter Property="CornerRadius" Value="9" />
    <Setter Property="Template">
      <ControlTemplate>
        <Border Name="root" Background="{TemplateBinding Background}"
                CornerRadius="9" Padding="11,9">
          <ContentPresenter Content="{TemplateBinding ContentPresenter.Content}"
                            ContentTemplate="{TemplateBinding ContentPresenter.ContentTemplate}" />
        </Border>
      </ControlTemplate>
    </Setter>
    <Setter Property="Transitions">
      <Transitions>
        <BrushTransition Property="Background" Duration="0:0:0.15" />
      </Transitions>
    </Setter>
  </Style>
  <Style Selector="ListBox.nav ListBoxItem:pointerover /template/ Border#root">
    <Setter Property="Background" Value="{DynamicResource BgCardHoverBrush}" />
  </Style>
  <Style Selector="ListBox.nav ListBoxItem:selected /template/ Border#root">
    <Setter Property="Background" Value="{DynamicResource AccentSoftBrush}" />
  </Style>

  <!-- Window control buttons -->
  <Style Selector="Button.wbtn">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Width" Value="44" />
    <Setter Property="Height" Value="34" />
    <Setter Property="CornerRadius" Value="0" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
  </Style>
  <Style Selector="Button.wbtn:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource BgCardHoverBrush}" />
  </Style>
  <Style Selector="Button.wclose:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource DangerBrush}" />
  </Style>

</Styles>
