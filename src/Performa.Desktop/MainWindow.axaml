<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Performa.Desktop.ViewModels"
        x:Class="Performa.Desktop.MainWindow"
        x:DataType="vm:MainViewModel"
        Title="Performa"
        Width="1200" Height="780"
        MinWidth="920" MinHeight="620"
        Background="{DynamicResource BgBackdrop}"
        SystemDecorations="None"
        CanResize="True">

  <Grid RowDefinitions="36,*">

    <!-- Title bar -->
    <Grid Grid.Row="0" Name="TitleBar" Background="Transparent"
          ColumnDefinitions="*,Auto">
      <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center"
                  Margin="14,0">
        <Border Width="14" Height="14" CornerRadius="4"
                Background="{DynamicResource AccentGradient}" />
        <TextBlock Text="Performa" Foreground="{DynamicResource TextMutedBrush}"
                   FontSize="12" FontWeight="SemiBold" Margin="9,0,0,0"
                   VerticalAlignment="Center" />
      </StackPanel>
      <StackPanel Grid.Column="1" Orientation="Horizontal">
        <Button Classes="wbtn" Command="{Binding ToggleConsoleCommand}"
                ToolTip.Tip="Console (embedded CLI)">
          <Path Data="{DynamicResource IconTerminal}" Fill="{DynamicResource TextMutedBrush}"
                Width="15" Height="15" Stretch="Uniform" />
        </Button>
        <Button Name="MinBtn" Classes="wbtn">
          <Rectangle Width="10" Height="1" Fill="{DynamicResource TextMutedBrush}" />
        </Button>
        <Button Name="MaxBtn" Classes="wbtn">
          <Rectangle Width="9" Height="9" Stroke="{DynamicResource TextMutedBrush}"
                     StrokeThickness="1" />
        </Button>
        <Button Name="CloseBtn" Classes="wbtn wclose">
          <Path Data="M0,0 L8,8 M8,0 L0,8" Stroke="{DynamicResource TextMutedBrush}"
                StrokeThickness="1.2" />
        </Button>
      </StackPanel>
    </Grid>

    <!-- Body -->
    <Grid Grid.Row="1" ColumnDefinitions="236,*">

      <!-- Sidebar -->
      <Border Grid.Column="0" Background="{DynamicResource BgSidebarBrush}"
              BorderBrush="{DynamicResource BorderSoftBrush}" BorderThickness="0,0,1,0">
        <DockPanel Margin="14,6,14,16">

          <StackPanel DockPanel.Dock="Top" Margin="4,10,4,18">
            <TextBlock Text="WORKSPACE" Classes="label" />
            <TextBlock Text="{Binding Engine.WorkspacePath, FallbackValue='Not set'}"
                       Classes="muted" TextTrimming="CharacterEllipsis" Margin="0,4,0,0" />
          </StackPanel>

          <StackPanel DockPanel.Dock="Bottom">
            <ListBox Classes="nav" ItemsSource="{Binding UtilityItems}"
                     SelectedItem="{Binding Selected, Mode=TwoWay}">
              <ListBox.ItemTemplate>
                <DataTemplate x:DataType="vm:NavItem">
                  <StackPanel Orientation="Horizontal">
                    <Path Data="{Binding Icon}" Fill="{DynamicResource TextMutedBrush}"
                          Width="17" Height="17" Stretch="Uniform"
                          VerticalAlignment="Center" />
                    <TextBlock Text="{Binding Title}" Margin="12,0,0,0"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               FontSize="13.5" VerticalAlignment="Center" />
                  </StackPanel>
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>
          </StackPanel>

          <ListBox DockPanel.Dock="Top" Classes="nav" ItemsSource="{Binding NavItems}"
                   SelectedItem="{Binding Selected, Mode=TwoWay}">
            <ListBox.ItemTemplate>
              <DataTemplate x:DataType="vm:NavItem">
                <StackPanel Orientation="Horizontal">
                  <Path Data="{Binding Icon}" Fill="{DynamicResource TextMutedBrush}"
                        Width="17" Height="17" Stretch="Uniform"
                        VerticalAlignment="Center" />
                  <TextBlock Text="{Binding Title}" Margin="12,0,0,0"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             FontSize="13.5" VerticalAlignment="Center" />
                  <Border Classes="chip" Margin="8,0,0,0" IsVisible="{Binding Dormant}"
                          VerticalAlignment="Center" Padding="6,1">
                    <TextBlock Text="soon" FontSize="9.5"
                               Foreground="{DynamicResource TextFaintBrush}" />
                  </Border>
                </StackPanel>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>

        </DockPanel>
      </Border>

      <!-- Content + console drawer -->
      <Border Grid.Column="1" Background="{DynamicResource BgContentBackdrop}">
      <Grid RowDefinitions="*,Auto">
        <TransitioningContentControl Grid.Row="0" Content="{Binding CurrentPage}">
          <TransitioningContentControl.PageTransition>
            <CrossFade Duration="0:0:0.18" />
          </TransitioningContentControl.PageTransition>
        </TransitioningContentControl>

        <Border Grid.Row="1" Name="ConsoleDrawer" Height="270" IsVisible="{Binding IsConsoleOpen}"
                Background="{DynamicResource BgInsetBrush}"
                BorderBrush="{DynamicResource BorderSoftBrush}" BorderThickness="0,1,0,0">
          <DockPanel>
            <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" Margin="16,9,8,6">
              <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <Path Data="{DynamicResource IconTerminal}" Width="13" Height="13"
                      Stretch="Uniform" Fill="{DynamicResource AccentBrightBrush}" />
                <TextBlock Text="CONSOLE" Classes="label" />
                <TextBlock Text="performa CLI, embedded" Classes="faint" />
              </StackPanel>
              <Button Grid.Column="1" Classes="wbtn" Command="{Binding ToggleConsoleCommand}">
                <Path Data="M0,0 L8,8 M8,0 L0,8" Stroke="{DynamicResource TextMutedBrush}"
                      StrokeThickness="1.2" />
              </Button>
            </Grid>

            <Grid DockPanel.Dock="Bottom" ColumnDefinitions="Auto,*" Margin="16,6,16,12"
                  VerticalAlignment="Center">
              <TextBlock Grid.Column="0" Text="›" FontFamily="{DynamicResource MonoFont}"
                         FontSize="14" Foreground="{DynamicResource AccentBrightBrush}"
                         VerticalAlignment="Center" Margin="0,0,8,0" />
              <TextBox Grid.Column="1" Name="ConsoleInput" Text="{Binding Console.Input}"
                       FontFamily="{DynamicResource MonoFont}" FontSize="13"
                       Watermark="standup · changelog · summary &lt;repo&gt; · loose · help"
                       Background="Transparent" BorderThickness="0" Padding="0">
                <TextBox.KeyBindings>
                  <KeyBinding Gesture="Enter" Command="{Binding Console.RunCommand}" />
                </TextBox.KeyBindings>
              </TextBox>
            </Grid>

            <ScrollViewer Margin="16,0" Name="ConsoleScroll">
              <SelectableTextBlock Text="{Binding Console.Output}"
                                   FontFamily="{DynamicResource MonoFont}" FontSize="12.5"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   TextWrapping="Wrap" LineHeight="19" />
            </ScrollViewer>
          </DockPanel>
        </Border>
      </Grid>
      </Border>

    </Grid>
  </Grid>
</Window>
