<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Performa.Desktop.ViewModels"
             x:Class="Performa.Desktop.Views.DailyView"
             x:DataType="vm:DailyViewModel">

  <Grid Margin="34,26,34,34" RowDefinitions="Auto,*">

    <StackPanel Grid.Row="0" Spacing="3" Margin="0,0,0,20">
      <TextBlock Text="Daily" Classes="h1" />
      <TextBlock Text="{Binding Today}" Classes="muted" />
    </StackPanel>

    <Grid Grid.Row="1" ColumnDefinitions="*,360" ColumnSpacing="18">

      <!-- Left: tasks + notes -->
      <Grid Grid.Column="0" RowDefinitions="Auto,*" RowSpacing="16">

        <Border Grid.Row="0" Classes="card">
          <StackPanel Spacing="12">
            <TextBlock Text="TASKS" Classes="label" />
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
              <TextBox Grid.Column="0" Text="{Binding NewTaskText}"
                       PlaceholderText="Add a task and press Enter…">
                <TextBox.KeyBindings>
                  <KeyBinding Gesture="Enter" Command="{Binding AddTaskCommand}" />
                </TextBox.KeyBindings>
              </TextBox>
              <Button Grid.Column="1" Classes="accent" Content="Add"
                      Command="{Binding AddTaskCommand}" />
            </Grid>
            <ItemsControl ItemsSource="{Binding Tasks}">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:TaskRow">
                  <CheckBox IsChecked="{Binding Done}" Margin="0,3">
                    <TextBlock Text="{Binding Text}" Foreground="{DynamicResource TextPrimaryBrush}"
                               VerticalAlignment="Center" TextWrapping="Wrap" />
                  </CheckBox>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
        </Border>

        <Border Grid.Row="1" Classes="card">
          <DockPanel>
            <TextBlock DockPanel.Dock="Top" Text="NOTES" Classes="label" Margin="0,0,0,10" />
            <TextBox Text="{Binding Notes}" AcceptsReturn="True" TextWrapping="Wrap"
                     PlaceholderText="Jot down anything about today…"
                     Background="Transparent" BorderThickness="0"
                     VerticalAlignment="Stretch" VerticalContentAlignment="Top" />
          </DockPanel>
        </Border>

      </Grid>

      <!-- Right: schedule + commits -->
      <ScrollViewer Grid.Column="1">
        <StackPanel Spacing="16">

          <Border Classes="card">
            <StackPanel Spacing="12">
              <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0" Text="SCHEDULE" Classes="label"
                           VerticalAlignment="Center" />
                <Button Grid.Column="1" Classes="spin" Classes.busy="{Binding IsRefreshing}"
                        IsVisible="{Binding GoogleConnected}"
                        ToolTip.Tip="Refresh (auto every 5 minutes)"
                        Command="{Binding RefreshCalendarCommand}">
                  <Path Data="{DynamicResource IconRefresh}" Width="14" Height="14"
                        Stretch="Uniform" Fill="{DynamicResource TextMutedBrush}" />
                </Button>
              </Grid>

              <TextBlock Text="{Binding CalendarStatus}" Classes="faint" TextWrapping="Wrap"
                         IsVisible="{Binding CalendarStatus, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />

              <ItemsControl ItemsSource="{Binding Events}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="vm:EventCard">
                    <Grid ColumnDefinitions="3,*" Margin="0,0,0,12">
                      <!-- colour node from your own Google palette -->
                      <Border Grid.Column="0" Background="{Binding Colour}" CornerRadius="2" />
                      <StackPanel Grid.Column="1" Spacing="2" Margin="11,0,0,0">
                        <TextBlock Text="{Binding Title}"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   FontSize="13" TextWrapping="Wrap" />
                        <StackPanel Orientation="Horizontal" Spacing="7">
                          <TextBlock Text="{Binding Day}" Classes="faint" FontSize="11" />
                          <TextBlock Text="{Binding Time}" Classes="mono" FontSize="11" />
                        </StackPanel>
                        <TextBlock Text="{Binding Location}" Classes="faint" FontSize="11"
                                   IsVisible="{Binding HasLocation}" TextWrapping="Wrap" />
                      </StackPanel>
                    </Grid>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </Border>

          <Border Classes="card">
            <StackPanel Spacing="12">
              <TextBlock Text="TODAY'S COMMITS" Classes="label" />
              <TextBlock Text="{Binding TimelineEmpty}" Classes="faint"
                         IsVisible="{Binding TimelineEmpty, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
              <ItemsControl ItemsSource="{Binding Timeline}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="vm:TimelineRow">
                    <Grid ColumnDefinitions="Auto,*" Margin="0,0,0,12">
                      <StackPanel Grid.Column="0" Margin="0,0,12,0">
                        <TextBlock Text="{Binding Time}" Classes="mono" FontSize="12"
                                   Foreground="{DynamicResource AccentBrightBrush}" />
                        <TextBlock Text="{Binding Repo}" Classes="faint" FontSize="10" />
                      </StackPanel>
                      <TextBlock Grid.Column="1" Text="{Binding Subject}" Classes="muted"
                                 FontSize="12.5" TextWrapping="Wrap" />
                    </Grid>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </Border>

        </StackPanel>
      </ScrollViewer>

    </Grid>
  </Grid>
</UserControl>
