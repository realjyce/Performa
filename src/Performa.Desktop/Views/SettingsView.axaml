<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Performa.Desktop.ViewModels"
             x:Class="Performa.Desktop.Views.SettingsView"
             x:DataType="vm:SettingsViewModel">

  <ScrollViewer>
    <StackPanel Margin="34,26,34,34" Spacing="18" MaxWidth="640" HorizontalAlignment="Left">

      <StackPanel Spacing="3">
        <TextBlock Text="Settings" Classes="h1" />
        <TextBlock Text="Where your repos come from and how reports read." Classes="muted" />
      </StackPanel>

      <Border Classes="card">
        <StackPanel Spacing="10">
          <TextBlock Text="YOUR NAME" Classes="label" />
          <TextBlock Classes="faint" TextWrapping="Wrap"
                     Text="What Performa calls you. Set here rather than taken from a Google profile." />
          <TextBox Text="{Binding UserName}" PlaceholderText="e.g. Jason" Margin="0,4,0,0" />
        </StackPanel>
      </Border>

      <Border Classes="card">
        <StackPanel Spacing="10">
          <TextBlock Text="STARTUP" Classes="label" />
          <CheckBox IsChecked="{Binding LaunchAtStartup}" Content="Launch Performa when Windows starts" />
          <TextBlock Classes="faint" TextWrapping="Wrap"
                     Text="Opens minimised so it is ready without interrupting your boot. You can also turn this off from Task Manager's Startup tab." />
          <TextBlock Text="{Binding StartupNote}" Classes="faint" TextWrapping="Wrap"
                     Foreground="{DynamicResource AccentBrightBrush}" />
        </StackPanel>
      </Border>

      <!-- Local repositories -->
      <Border Classes="card">
        <StackPanel Spacing="10">
          <TextBlock Text="LOCAL REPOSITORIES" Classes="label" />
          <TextBlock Text="Performa scans this folder for git repositories." Classes="faint" />
          <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8" Margin="0,4,0,0">
            <TextBox Grid.Column="0" Text="{Binding WorkspacePath}"
                     PlaceholderText="C:\path\to\your\repos" />
            <Button Grid.Column="1" Classes="ghost" Content="Change…" Click="OnBrowse" />
            <Button Grid.Column="2" Classes="accent" Content="Auto-detect"
                    Command="{Binding AutoDetectCommand}" />
          </Grid>
          <TextBlock Text="{Binding LocalNote}" Classes="faint" TextWrapping="Wrap" />
        </StackPanel>
      </Border>

      <!-- GitHub -->
      <Border Classes="card">
        <StackPanel Spacing="10">
          <Grid ColumnDefinitions="*,Auto">
            <TextBlock Grid.Column="0" Text="GITHUB" Classes="label" VerticalAlignment="Center" />
            <Border Grid.Column="1" Classes="chip" IsVisible="{Binding GitHubConnected}"
                    Background="{DynamicResource AccentSoftBrush}"
                    BorderBrush="{DynamicResource AccentBrush}">
              <TextBlock Text="connected" FontSize="10.5"
                         Foreground="{DynamicResource AccentBrightBrush}" />
            </Border>
          </Grid>
          <TextBlock Classes="faint" TextWrapping="Wrap"
                     Text="Lists every repo you can see, including private ones, and clones the ones missing here. Signing in uses GitHub's device flow: you approve a short code on github.com and Performa never handles your password." />

          <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,4,0,0">
            <Button Classes="accent" Content="Sign in with GitHub"
                    Command="{Binding GitHubSignInCommand}" />
            <Button Classes="ghost" Content="Scan repositories"
                    Command="{Binding ScanGitHubCommand}" />
            <Button Classes="ghost" Content="Disconnect" IsVisible="{Binding GitHubConnected}"
                    Command="{Binding GitHubSignOutCommand}" />
          </StackPanel>

          <!-- The code GitHub wants typed into the browser. -->
          <Border IsVisible="{Binding HasDeviceCode}" CornerRadius="8" Padding="14,12"
                  Background="{DynamicResource AccentSoftBrush}"
                  BorderBrush="{DynamicResource AccentBrush}" BorderThickness="1">
            <StackPanel Spacing="5">
              <TextBlock Text="ENTER THIS CODE ON GITHUB" Classes="label"
                         Foreground="{DynamicResource AccentBrightBrush}" />
              <SelectableTextBlock Text="{Binding DeviceCode}" Classes="mono" FontSize="24"
                                   Foreground="{DynamicResource TextPrimaryBrush}" />
              <TextBlock Text="Waiting for you to approve it…" Classes="faint" FontSize="11" />
            </StackPanel>
          </Border>

          <TextBlock Text="{Binding GitHubNote}" Classes="faint" TextWrapping="Wrap" />

          <Button Classes="ghost" Content="Advanced: use my own GitHub app"
                  HorizontalAlignment="Left" FontSize="12"
                  Command="{Binding ToggleGitHubAdvancedCommand}" />
          <StackPanel Spacing="8" IsVisible="{Binding ShowGitHubAdvanced}">
            <TextBlock Classes="faint" TextWrapping="Wrap"
                       Text="Not needed to sign in. Fill these only to point Performa at your own OAuth App, or to fall back to a personal token." />
            <TextBox Text="{Binding GitHubClientId}" PlaceholderText="OAuth App client id  (Ov23…)" />
            <TextBox Text="{Binding GitHubToken}" PasswordChar="•"
                     PlaceholderText="Personal token  (ghp_…)" />
          </StackPanel>

          <Border IsVisible="{Binding GitHubRepos.Count}" MaxHeight="260"
                  Background="{DynamicResource BgInsetBrush}" CornerRadius="8" Padding="4">
            <ScrollViewer>
              <ItemsControl ItemsSource="{Binding GitHubRepos}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="vm:GitHubRepoRow">
                    <Grid ColumnDefinitions="*,86" Margin="10,7">
                      <StackPanel Grid.Column="0" Spacing="1" Margin="0,0,10,0">
                        <TextBlock Text="{Binding Name}"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   FontSize="13" TextTrimming="CharacterEllipsis" />
                        <TextBlock Text="{Binding Meta}" Classes="faint" FontSize="11"
                                   TextTrimming="CharacterEllipsis" />
                        <TextBlock Text="{Binding Status}" Classes="faint" FontSize="11"
                                   Foreground="{DynamicResource AccentBrightBrush}"
                                   TextTrimming="CharacterEllipsis" />
                      </StackPanel>
                      <Button Grid.Column="1" Classes="ghost" Content="Clone"
                              HorizontalAlignment="Right" VerticalAlignment="Center"
                              IsVisible="{Binding CanClone}"
                              Command="{Binding $parent[ItemsControl].((vm:SettingsViewModel)DataContext).CloneCommand}"
                              CommandParameter="{Binding}" />
                      <TextBlock Grid.Column="1" Text="on disk" Classes="faint"
                                 HorizontalAlignment="Right" VerticalAlignment="Center"
                                 IsVisible="{Binding IsLocal}" />
                    </Grid>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </ScrollViewer>
          </Border>
        </StackPanel>
      </Border>

      <!-- Google -->
      <Border Classes="card">
        <StackPanel Spacing="10">
          <Grid ColumnDefinitions="*,Auto">
            <TextBlock Grid.Column="0" Text="GOOGLE" Classes="label" VerticalAlignment="Center" />
            <Border Grid.Column="1" Classes="chip" IsVisible="{Binding GoogleConnected}"
                    Background="{DynamicResource AccentSoftBrush}"
                    BorderBrush="{DynamicResource AccentBrush}">
              <TextBlock Text="connected" FontSize="10.5"
                         Foreground="{DynamicResource AccentBrightBrush}" />
            </Border>
          </Grid>
          <TextBlock Classes="faint" TextWrapping="Wrap"
                     Text="Read-only access to your Calendar and Gmail. Performa can never send mail or change your calendar." />

          <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,4,0,0">
            <Button Classes="accent" Content="Sign in with Google"
                    Command="{Binding GoogleSignInCommand}" />
            <Button Classes="ghost" Content="Disconnect" IsVisible="{Binding GoogleConnected}"
                    Command="{Binding GoogleSignOutCommand}" />
          </StackPanel>
          <TextBlock Text="{Binding GoogleStatus}" Classes="faint" TextWrapping="Wrap" />

          <Button Classes="ghost" Content="Advanced: use my own Google client"
                  HorizontalAlignment="Left" FontSize="12"
                  Command="{Binding ToggleGoogleAdvancedCommand}" />
          <StackPanel Spacing="8" IsVisible="{Binding ShowGoogleAdvanced}">
            <TextBlock Classes="faint" TextWrapping="Wrap"
                       Text="Only needed if you want Performa to use your own Google Cloud project instead of the built-in one." />
            <TextBox Text="{Binding GoogleClientId}"
                     PlaceholderText="Client ID  (…apps.googleusercontent.com)" />
            <TextBox Text="{Binding GoogleClientSecret}" PasswordChar="•"
                     PlaceholderText="Client secret  (GOCSPX-…)" />
          </StackPanel>
        </StackPanel>
      </Border>

      <!-- AI -->
      <Border Classes="card">
        <StackPanel Spacing="10">
          <TextBlock Text="AI" Classes="label" />
          <TextBlock Classes="faint" TextWrapping="Wrap"
                     Text="Adds prose on top of the facts: a readable answer in the Assistant and a short read of each email. The extracted facts never go away, so turning this off loses nothing. When enabled, commit subjects and email text are sent to whichever provider you pick below." />
          <CheckBox IsChecked="{Binding AiEnabled}" Margin="0,4,0,0">
            <TextBlock Text="Enable AI prose" Foreground="{DynamicResource TextPrimaryBrush}" />
          </CheckBox>

          <StackPanel Spacing="7" IsVisible="{Binding AiEnabled}">
            <TextBlock Text="PROVIDER" Classes="label" FontSize="10" />
            <ComboBox ItemsSource="{Binding AiProviders}"
                      SelectedItem="{Binding AiProvider}" HorizontalAlignment="Stretch" />
            <TextBlock Text="{Binding AiKeyHint}" Classes="faint" FontSize="11"
                       TextWrapping="Wrap" />

            <!-- One field per provider, so switching back never costs a re-paste. -->
            <StackPanel Spacing="5" IsVisible="{Binding IsGemini}">
              <TextBox Text="{Binding GeminiKey}" PasswordChar="•"
                       PlaceholderText="Your own Gemini key (optional)" />
              <TextBlock Classes="faint" FontSize="11" TextWrapping="Wrap"
                         Text="Gemini has a free tier and this build ships with a shared key, so you can leave this empty. Your own key always wins." />
            </StackPanel>

            <StackPanel Spacing="5" IsVisible="{Binding IsClaude}">
              <TextBox Text="{Binding AnthropicKey}" PasswordChar="•"
                       PlaceholderText="Your Anthropic key" />
              <TextBlock Classes="faint" FontSize="11" TextWrapping="Wrap"
                         Text="Billed per token, so this key is yours to supply. Nothing is sent until you paste one." />
            </StackPanel>

            <StackPanel Spacing="5" IsVisible="{Binding IsOpenAi}">
              <TextBox Text="{Binding OpenAiKey}" PasswordChar="•"
                       PlaceholderText="Your OpenAI key" />
              <TextBlock Classes="faint" FontSize="11" TextWrapping="Wrap"
                         Text="Billed per token, so this key is yours to supply. Nothing is sent until you paste one." />
            </StackPanel>
          </StackPanel>
        </StackPanel>
      </Border>

      <!-- Appearance -->
      <Border Classes="card">
        <StackPanel Spacing="10">
          <TextBlock Text="APPEARANCE" Classes="label" />
          <Grid ColumnDefinitions="*,Auto">
            <StackPanel Grid.Column="0" Spacing="2" Margin="0,0,16,0">
              <TextBlock Text="{Binding ThemeLabel}"
                         Foreground="{DynamicResource TextPrimaryBrush}" FontSize="13" />
              <TextBlock Classes="faint" FontSize="11" TextWrapping="Wrap"
                         Text="Carbon is the dark weave. Paper keeps the same texture on a light surface. Applies straight away." />
            </StackPanel>
            <ToggleSwitch Grid.Column="1" IsChecked="{Binding IsLightTheme}"
                          OnContent="" OffContent="" VerticalAlignment="Center" />
          </Grid>
        </StackPanel>
      </Border>

      <!-- Output -->
      <Border Classes="card">
        <StackPanel Spacing="14">
          <TextBlock Text="OUTPUT" Classes="label" />
          <Grid ColumnDefinitions="140,*" RowDefinitions="Auto,Auto,Auto" RowSpacing="12">
            <TextBlock Grid.Row="0" Grid.Column="0" Text="Verbosity" Classes="muted"
                       VerticalAlignment="Center" />
            <ComboBox Grid.Row="0" Grid.Column="1" Width="200" HorizontalAlignment="Left"
                      ItemsSource="{Binding Verbosities}" SelectedItem="{Binding Verbosity}" />
            <TextBlock Grid.Row="1" Grid.Column="0" Text="Grouping" Classes="muted"
                       VerticalAlignment="Center" />
            <ComboBox Grid.Row="1" Grid.Column="1" Width="200" HorizontalAlignment="Left"
                      ItemsSource="{Binding Groupings}" SelectedItem="{Binding Grouping}" />
            <TextBlock Grid.Row="2" Grid.Column="0" Text="Tone" Classes="muted"
                       VerticalAlignment="Center" />
            <ComboBox Grid.Row="2" Grid.Column="1" Width="200" HorizontalAlignment="Left"
                      ItemsSource="{Binding Tones}" SelectedItem="{Binding Tone}" />
          </Grid>
        </StackPanel>
      </Border>

      <StackPanel Orientation="Horizontal" Spacing="14">
        <Button Classes="accent" Content="Save preferences" Command="{Binding SaveCommand}" />
        <TextBlock Text="{Binding SavedNote}" Classes="muted" VerticalAlignment="Center" />
      </StackPanel>

    </StackPanel>
  </ScrollViewer>
</UserControl>
