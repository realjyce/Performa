<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Performa.Desktop.ViewModels"
             x:Class="Performa.Desktop.Views.AssistantView"
             x:DataType="vm:AssistantViewModel">

  <Grid Margin="34,26,34,26" RowDefinitions="Auto,*,Auto,Auto">

    <StackPanel Grid.Row="0" Spacing="3" Margin="0,0,0,18">
      <TextBlock Text="Assistant" Classes="h1" />
      <TextBlock Text="Answers from your git facts. Deterministic today, AI-ready behind one seam." Classes="muted" />
    </StackPanel>

    <!-- Conversation -->
    <ScrollViewer Grid.Row="1">
      <ItemsControl ItemsSource="{Binding Messages}">
        <ItemsControl.ItemTemplate>
          <DataTemplate x:DataType="vm:ChatMessage">
            <Grid Margin="0,0,0,12">
              <Border Classes="card" MaxWidth="560" HorizontalAlignment="Left"
                      IsVisible="{Binding IsAssistant}"
                      Background="{DynamicResource BgCardBrush}">
                <TextBlock Text="{Binding Text}" Classes="muted" FontSize="13.5"
                           TextWrapping="Wrap" LineHeight="20" />
              </Border>
              <Border MaxWidth="560" HorizontalAlignment="Right"
                      IsVisible="{Binding IsUser}"
                      Background="{DynamicResource AccentSoftBrush}"
                      BorderBrush="{DynamicResource AccentBrush}" BorderThickness="1"
                      CornerRadius="12" Padding="16,11">
                <TextBlock Text="{Binding Text}" Foreground="{DynamicResource TextPrimaryBrush}"
                           FontSize="13.5" TextWrapping="Wrap" />
              </Border>
            </Grid>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </ScrollViewer>

    <!-- Suggestions -->
    <ItemsControl Grid.Row="2" ItemsSource="{Binding Suggestions}" Margin="0,10,0,12">
      <ItemsControl.ItemsPanel>
        <ItemsPanelTemplate>
          <StackPanel Orientation="Horizontal" Spacing="8" />
        </ItemsPanelTemplate>
      </ItemsControl.ItemsPanel>
      <ItemsControl.ItemTemplate>
        <DataTemplate x:DataType="x:String">
          <Button Classes="ghost" Content="{Binding}"
                  Command="{Binding $parent[ItemsControl].((vm:AssistantViewModel)DataContext).AskSuggestionCommand}"
                  CommandParameter="{Binding}" />
        </DataTemplate>
      </ItemsControl.ItemTemplate>
    </ItemsControl>

    <!-- Input -->
    <Grid Grid.Row="3" ColumnDefinitions="*,Auto" ColumnSpacing="10">
      <TextBox Grid.Column="0" Text="{Binding Input}" Watermark="Ask about your work…">
        <TextBox.KeyBindings>
          <KeyBinding Gesture="Enter" Command="{Binding SendCommand}" />
        </TextBox.KeyBindings>
      </TextBox>
      <Button Grid.Column="1" Classes="accent" Content="Send" Command="{Binding SendCommand}" />
    </Grid>

  </Grid>
</UserControl>
