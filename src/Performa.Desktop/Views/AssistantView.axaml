<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Performa.Desktop.ViewModels"
             xmlns:c="clr-namespace:Performa.Desktop.Controls"
             x:Class="Performa.Desktop.Views.AssistantView"
             x:DataType="vm:AssistantViewModel">

  <Grid Margin="34,26,34,26" RowDefinitions="Auto,*,Auto,Auto,Auto">

    <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,18">
      <StackPanel Grid.Column="0" Spacing="3">
        <TextBlock Text="Assistant" Classes="h1" />
        <TextBlock Text="Reads your git history and answers from facts. Prose comes from a model; the facts never do." Classes="muted" />
      </StackPanel>
      <Border Grid.Column="1" Classes="chip" VerticalAlignment="Center"
              IsVisible="{Binding HasActiveModel}"
              Background="{DynamicResource AccentSoftBrush}"
              BorderBrush="{DynamicResource AccentBrush}">
        <TextBlock Text="{Binding ActiveModel}" Classes="mono" FontSize="10.5"
                   Foreground="{DynamicResource AccentBrightBrush}" />
      </Border>
    </Grid>

    <!-- Conversation -->
    <ScrollViewer Grid.Row="1">
      <ItemsControl ItemsSource="{Binding Messages}">
        <ItemsControl.ItemTemplate>
          <DataTemplate x:DataType="vm:ChatMessage">
            <Grid Margin="0,0,0,12">
              <Border Classes="card" MaxWidth="560" HorizontalAlignment="Left"
                      IsVisible="{Binding IsAssistant}"
                      Background="{DynamicResource BgCardBrush}">
                <StackPanel Spacing="8">
                  <TextBlock Text="{Binding Text}" Classes="muted" FontSize="13.5"
                             TextWrapping="Wrap" LineHeight="20" />
                  <StackPanel Orientation="Horizontal" Spacing="6"
                              IsVisible="{Binding HasSource}">
                    <Ellipse Width="4" Height="4" VerticalAlignment="Center"
                             Fill="{DynamicResource TextFaintBrush}" />
                    <TextBlock Text="{Binding Source}" Classes="mono" FontSize="10"
                               Foreground="{DynamicResource TextFaintBrush}" />
                  </StackPanel>
                </StackPanel>
              </Border>
              <Border MaxWidth="560" HorizontalAlignment="Right"
                      IsVisible="{Binding IsUser}"
                      Background="{DynamicResource AccentSoftBrush}"
                      BorderBrush="{DynamicResource AccentBrush}" BorderThickness="1"
                      CornerRadius="12" Padding="16,11">
                <TextBlock Text="{Binding Text}" Foreground="{DynamicResource TextPrimaryBrush}"
                           FontSize="13.5" TextWrapping="Wrap" />
              </Border>
            </Grid>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </ScrollViewer>

    <!-- Working mark: sits where the next answer will land -->
    <Border Grid.Row="2" Classes="card" HorizontalAlignment="Left" Padding="18,12"
            IsVisible="{Binding Thinking}" Margin="0,0,0,10">
      <c:ThinkingDots Width="54" Height="26"
                      IsActive="{Binding Thinking}"
                      DotBrush="{DynamicResource AccentBrightBrush}" />
    </Border>

    <!-- Suggestions -->
    <ItemsControl Grid.Row="3" ItemsSource="{Binding Suggestions}" Margin="0,10,0,12">
      <ItemsControl.ItemsPanel>
        <ItemsPanelTemplate>
          <StackPanel Orientation="Horizontal" Spacing="8" />
        </ItemsPanelTemplate>
      </ItemsControl.ItemsPanel>
      <ItemsControl.ItemTemplate>
        <DataTemplate x:DataType="x:String">
          <Button Classes="ghost" Content="{Binding}"
                  Command="{Binding $parent[ItemsControl].((vm:AssistantViewModel)DataContext).AskSuggestionCommand}"
                  CommandParameter="{Binding}" />
        </DataTemplate>
      </ItemsControl.ItemTemplate>
    </ItemsControl>

    <!-- Input -->
    <Grid Grid.Row="4" ColumnDefinitions="*,Auto" ColumnSpacing="10">
      <TextBox Grid.Column="0" Text="{Binding Input}" PlaceholderText="Ask about your work…">
        <TextBox.KeyBindings>
          <KeyBinding Gesture="Enter" Command="{Binding SendCommand}" />
        </TextBox.KeyBindings>
      </TextBox>
      <Button Grid.Column="1" Classes="accent" Content="Send" Command="{Binding SendCommand}" />
    </Grid>

  </Grid>
</UserControl>
